# ═══════════════════════════════════════════════════════════════════════════════
# .gitignore — DocuPick Universal Viewer
# ═══════════════════════════════════════════════════════════════════════════════

# ─── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.swp
*.swo
*~

# ─── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
package-lock.json

# ─── React Native / Metro ────────────────────────────────────────────────────
*.jsbundle
*.bundle
.metro-health-check*

# ─── Xcode / iOS ─────────────────────────────────────────────────────────────
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.ipa
*.xcuserstate
**/.xcode.env.local
ios/Pods/
ios/build/

# ─── Android / Gradle ────────────────────────────────────────────────────────
*.apk
*.aab
*.dex
*.class
*.iml
*.hprof
*.keystore
!debug.keystore
.gradle/
.idea/
.cxx/
.kotlin/
local.properties
android/app/build/
android/build/
android/.gradle/

# ─── CocoaPods / Ruby ────────────────────────────────────────────────────────
**/Pods/
/vendor/bundle/
Gemfile.lock
.bundle/

# ─── Fastlane ─────────────────────────────────────────────────────────────────
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots/
**/fastlane/test_output/

# ─── Testing / Coverage ──────────────────────────────────────────────────────
/coverage/
*.lcov
jest-report/

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ─── Environment / Secrets ───────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.p12
*.key

# ─── Build Artifacts ─────────────────────────────────────────────────────────
dist/
out/
*.tgz

# ─── Temporary Files ─────────────────────────────────────────────────────────
*.tmp
*.temp
*.log
